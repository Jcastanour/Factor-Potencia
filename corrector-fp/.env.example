# Selección de adapters (composition root: src/infrastructure/container.ts)
# - simulated: generador determinista, no acepta writes
# - in-memory: solo lo que ingestó hardware (RAM)
# - hybrid:    in-memory si hay lectura <60s, sino simulated   ← default v1
# - postgres:  stub, no funcional hasta conectar Drizzle (ver plan)
TELEMETRY_SOURCE=hybrid

# Mailer
# - console: imprime el email a stdout (default v1)
# - resend:  stub, no funcional hasta agregar el package y RESEND_API_KEY
MAILER=console

# Device demo (autenticación de telemetry/ingest)
DEMO_DEVICE_ID=demo-device
DEMO_DEVICE_API_KEY=demo-key-change-me-please

# Notificación de leads (visible en consola en modo console)
LEAD_NOTIFY_EMAIL=equipo@example.com
LEAD_FROM_EMAIL=onboarding@resend.dev

# Persistencia opcional de leads (append-only; útil para no perder datos en reload)
LEADS_JSONL_PATH=tmp/leads.jsonl

# Solo cuando se activen los adapters reales:
# RESEND_API_KEY=
# DATABASE_URL=
